# Splunk connection settings
# Copy this file to .env and fill in your values

# Splunk server hostname or IP address
SPLUNK_HOST=10.0.0.1

# Splunk management API port (default: 8089)
SPLUNK_PORT=8089

# Authentication: use token (preferred) OR username + password
# To generate a token: Splunk Web → Settings → Tokens → New Token
SPLUNK_TOKEN=your-splunk-bearer-token-here

# Fallback: username/password (used only when SPLUNK_TOKEN is not set)
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme

# Set to "true" only if Splunk has a valid, trusted TLS certificate
# For lab/dev environments with self-signed certs, leave as "false"
SPLUNK_VERIFY_SSL=false
