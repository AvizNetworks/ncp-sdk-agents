from ncp import tool
import os
import re

@tool
def create_visualization(traceroute_output: str) -> str:
    """
    Parses traceroute text, builds an interactive graph, and saves it 
    to the 'reports' directory as an HTML file.
    """
    # CRITICAL FIX: Lazy import allows agent to deploy before installing requirements
    from pyvis.network import Network

    # 1. Setup Output Directory: 'reports' folder in project root
    # base_dir is the folder containing 'tools', so project root is one level up
    base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    output_dir = os.path.join(base_dir, "reports")
    
    # Ensure directory exists
    try:
        os.makedirs(output_dir, exist_ok=True)
    except Exception:
        # Fallback to /tmp if current dir is locked (container permission safety)
        output_dir = "/tmp/reports"
        os.makedirs(output_dir, exist_ok=True)

    filename = os.path.join(output_dir, "latest_trace.html")

    # 2. Parse the Traceroute Data
    # Regex to find lines like: " 1  20.20.20.3 (20.20.20.3)  0.350 ms..."
    hop_pattern = re.compile(r'\s*(\d+)\s+([\d\.]+)\s+\(([\d\.]+)\)\s+([\d\.]+)\s+ms')
    
    hops = []
    lines = traceroute_output.split('\n')
    
    # Try to find Source/Dest from the header "traceroute to X (X)..."
    header_pattern = re.compile(r'traceroute to ([\d\.]+)')
    target_ip = "Unknown"
    for line in lines:
        m = header_pattern.search(line)
        if m:
            target_ip = m.group(1)
            break

    for line in lines:
        match = hop_pattern.search(line)
        if match:
            hops.append({
                "hop": int(match.group(1)), 
                "ip": match.group(3), 
                "latency": match.group(4)
            })

    if not hops:
        return "Could not extract hop data from text. Map not generated."

    # 3. Build the Graph
    net = Network(height="600px", width="100%", bgcolor="#222222", font_color="white")
    
    # Add Nodes
    previous_node = "Source" # Abstract start node
    net.add_node(previous_node, label="Start", color="#00ff00", shape="box") # Green for Start

    for hop in hops:
        current_node = hop['ip']
        label_text = f"Hop {hop['hop']}\n{current_node}"
        
        # Color logic: Destination gets Red, Hops get Blue
        color = "#ff5555" if current_node == target_ip else "#44aaff"
        shape = "star" if current_node == target_ip else "dot"
        
        net.add_node(current_node, label=label_text, color=color, shape=shape)
        
        # Add Edge (Link) with Latency Label
        edge_label = f"{hop['latency']} ms"
        net.add_edge(previous_node, current_node, label=edge_label, color="#aaaaaa")
        
        previous_node = current_node

    # 4. Save file
    try:
        net.save_graph(filename)
        # Return path so user knows where it is
        return f"SUCCESS: Interactive map saved to: {filename}"
    except Exception as e:
        return f"Error saving HTML file: {str(e)}"
